import org.apache.jmeter.protocol.jdbc.config.DataSourceElement;
import java.sql.Connection;
import java.sql.PreparedStatement;

log.info("Inserting JMeter result into PostgreSQL");

try {
    // Get connection differently for BeanShell
    Connection conn = DataSourceElement.getConnection("dbConnection");

    if (conn == null) {
        log.error("DB Connection is null!");
        return;
    }

    String sql = "INSERT INTO \"PerformanceTestResults\".jmeter_results " +
                 "(timestamp, elapsed, label, response_code, " +
                 "response_message, thread_name, success, " +
                 "bytes, sent_bytes, grp_threads, all_threads, " +
                 "latency, connect) " +
                 "VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?)";

    PreparedStatement stmt = conn.prepareStatement(sql);
    stmt.setLong   (1,  sampleResult.getStartTime());
    stmt.setInt    (2,  (int) sampleResult.getTime());
    stmt.setString (3,  sampleResult.getSampleLabel());
    stmt.setString (4,  sampleResult.getResponseCode());

    String respMsg = sampleResult.getResponseMessage();
    stmt.setString (5,  respMsg != null ?
                    respMsg.substring(0, Math.min(255, respMsg.length())) : "");

    stmt.setString (6,  sampleResult.getThreadName());
    stmt.setBoolean(7,  sampleResult.isSuccessful());
    stmt.setInt    (8,  (int) sampleResult.getBytesAsLong());
    stmt.setInt    (9,  (int) sampleResult.getSentBytes());
    stmt.setInt    (10, sampleResult.getGroupThreads());
    stmt.setInt    (11, sampleResult.getAllThreads());
    stmt.setInt    (12, (int) sampleResult.getLatency());
    stmt.setInt    (13, (int) sampleResult.getConnectTime());
    stmt.executeUpdate();
    stmt.close();
    conn.close();

    log.info("Row inserted: " + sampleResult.getSampleLabel());

} catch (Exception e) {
    log.error("Error: " + e.getMessage());
}